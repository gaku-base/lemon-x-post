+/* v4.10.2 final slim POST CONCIERGE header */
+.compact-hero{border:1px solid rgba(115,87,48,.12);border-radius:20px;background:linear-gradient(105deg,#fbf4e9 0%,#fff9ec 56%,#f7e3ac 100%);box-shadow:0 7px 18px rgba(96,78,67,.07)}
+.compact-hero::after{display:none}
+.hero-brand{grid-template-columns:112px minmax(0,1fr);min-height:126px}
+.sandokun-mascot{min-height:126px;background:#f8efe4;border-right-color:rgba(115,87,48,.1)}
+.sandokun-mascot::after{background:linear-gradient(90deg,transparent 76%,rgba(248,239,228,.68) 92%,rgba(248,239,228,.95))}
+.sandokun-mascot img{object-fit:contain;object-position:center;transform:scale(1.03)}
+.hero-copy{position:relative;padding:18px 46px 15px 16px}
+.hero-copy .hero-top{position:absolute;top:9px;right:10px;margin:0}
+.compact-hero .eyebrow,.compact-hero .hero-copy p,.brand-lockup h1{display:none}
+.brand-lockup{padding:0}
+.brand-series{margin-bottom:6px;color:#3f5d43;font-family:"Hiragino Sans","Yu Gothic",Meiryo,sans-serif;font-size:11px;font-weight:800;letter-spacing:.08em}
+.brand-series span{font-family:"Avenir Next",Avenir,"Helvetica Neue",Arial,sans-serif;font-size:.92em;font-style:normal;font-weight:700;letter-spacing:.04em}
+.brand-english{display:block;color:#5a4639;font-family:"Avenir Next",Avenir,"Helvetica Neue",Arial,sans-serif;font-size:24px;font-weight:750;line-height:1.02;letter-spacing:.045em;white-space:nowrap}
+.brand-english::after{display:none}
